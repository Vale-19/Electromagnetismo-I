Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Par\[AAcute]metros"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"phi0", "=", "5"}], ";", 
    RowBox[{"a", "=", "1"}], ";", 
    RowBox[{"b", "=", "1"}], ";", 
    RowBox[{"nMax", "=", "25"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", "Definici\[OAcute]n", " ", "del", " ", "Potencial"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"phi", "[", 
      RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"16", "*", 
        RowBox[{"phi0", "/", 
         RowBox[{"Pi", "^", "2"}]}]}], ")"}], "*", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", 
           RowBox[{"(", 
            RowBox[{"n", "*", "m"}], ")"}]}], ")"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "Pi"}], "*", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"n", "/", "a"}], ")"}], "^", "2"}], "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"m", "/", "b"}], ")"}], "^", "2"}]}], "]"}], "*", 
           "x"}], "]"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"n", "*", "Pi", "*", 
           RowBox[{"y", "/", "a"}]}], "]"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"m", "*", "Pi", "*", 
           RowBox[{"z", "/", "b"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "1", ",", "nMax", ",", "2"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"m", ",", "1", ",", "nMax", ",", "2"}], "}"}]}], "]"}]}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Distancia", " ", "interactiva", " ", "en", " ", "el", " ", 
     "eje", " ", "x"}], "*)"}], "\n", 
   RowBox[{"Manipulate", "[", 
    RowBox[{
     RowBox[{"SliceDensityPlot3D", "[", 
      RowBox[{
       RowBox[{"phi", "[", 
        RowBox[{"x", ",", "y", ",", "z"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"\"\<CenterPlane\>\"", ",", 
         RowBox[{"x", "==", "xCorte"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "2.5"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "0", ",", "a"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "0", ",", "b"}], "}"}], ",", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{"0", ",", "phi0"}], "}"}]}], ",", 
       RowBox[{"ColorFunction", "->", "\"\<TemperatureMap\>\""}], ",", 
       RowBox[{"PlotLegends", "->", "Automatic"}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{
         "\"\<Eje X\>\"", ",", "\"\<Eje Y\>\"", ",", "\"\<Eje Z\>\""}], 
         "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"Style", "[", 
         RowBox[{
         "\"\<Mapeo del Potencial \[Phi](x,y,z) dentro del tubo\>\"", ",", 
          "14", ",", "Bold"}], "]"}]}], ",", 
       RowBox[{"ImageSize", "->", "Large"}], ",", 
       RowBox[{"PerformanceGoal", "->", "\"\<Quality\>\""}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"xCorte", ",", "0.01", ",", "\"\<Profundidad (Eje X)\>\""}], 
        "}"}], ",", "0.01", ",", "2.4", ",", 
       RowBox[{"Appearance", "->", "\"\<Labeled\>\""}]}], "}"}]}], 
    "]"}]}]}]], "Input",
